# Database Connection URL
DATABASE_URL=postgres://pipe_bolt_app:secure_prod_password@prod-db-instance.c12345.ap-southeast-1.rds.amazonaws.com:5432/pipe_bolt_production
PIPE_BOLT_DATABASE_URL=postgres://pipe_bolt_app:secure_prod_password@prod-db-instance.c12345.ap-southeast-1.rds.amazonaws.com:5432/pipe_bolt_production

# Database Pool Configuration
PIPE_BOLT_STORAGE_MAX_CONNECTIONS=20

# Database Migrations: Set to false if you run migrations during CI/CD deploy pipeline
PIPE_BOLT_STORAGE_RUN_MIGRATIONS=false

# Production Project Settings
PIPE_BOLT_PROJECT_ID=project-prod-main

# Always set bootstrap to false in production to prevent overwriting 
# production database configurations with local JSON files.
PIPE_BOLT_PROJECT_CONFIG_BOOTSTRAP=false

# Storage Cryptography Keys (Using secure 32-byte AES-256 keys in Base64)
# Make sure to rotate keys using multiple active keyring array (3 key) for security.
PIPE_BOLT_STORAGE_KEYS=key-2026-v1=eDR4T3pLcDZac2RmWGd5aGprbG1ub3BxcnN0dXZ3eHk=,key-2026-v2=RzdaOHc5djB1MXQycjNzNHA1bzZuN204bDlrM2oyMTQ=
PIPE_BOLT_STORAGE_ACTIVE_KEY_ID=key-2026-v2

# Management API Security
PIPE_BOLT_MANAGEMENT_API_ENABLED=true

# Bind only to internal private network or localhost to prevent public internet access.
# If running in Kubernetes/Docker behind a service mesh or reverse proxy, use 0.0.0.0.
PIPE_BOLT_MANAGEMENT_BIND_ADDR=0.0.0.0:8081

# A cryptographically secure random token (e.g. generated via `openssl rand -hex 32`)
PIPE_BOLT_MANAGEMENT_TOKEN=8c7d6c6e7a2b9e8c3a1d4f6e5d8c3b2a1a0f9e8d7c6b5a4f3e2d1c0b9a8f7e6d

# Production Logging Level
# Restrict logs to INFO and WARN/ERROR to avoid performance degradation and log bloating.
PIPE_BOLT_LOG=pipe_bolt_daemon=info,pipe_bolt_core=info,pipe_bolt_api=info,warn