{
  "id": "project-dev-1",
  "name": "Local Development Project",
  "description": "Project configuration for local development",
  "enabled": true,
  "version": 1,
  "brokers": [
    {
      "id": "broker-local",
      "name": "Local MQTT Broker",
      "host": "127.0.0.1",
      "port": 1883,
      "tls": "disabled",
      "keep_alive": 30,
      "clean_session": true,
      "client_id": "pipe-bolt-local-client",
      "reconnect": {
        "min_delay": 500,
        "max_delay": 30000
      },
      "enabled": true
    }
  ],
  "routes": [
    {
      "id": "route-local-telemetry",
      "broker_id": "broker-local",
      "name": "Local Telemetry Route",
      "topic_filter": "device/+/telemetry",
      "codec": "json",
      "schema_mapping_id": null,
      "device_id": {
        "type": "topic_wildcard_index",
        "index": 0
      },
      "event_type": "telemetry",
      "qos": "at_most_once",
      "enabled": true,
      "backpressure": "reject"
    }
  ],
  "rules": [
    {
      "id": "rule-stream-telemetry",
      "name": "Stream Telemetry to UI",
      "enabled": true,
      "trigger": {
        "type": "event_received"
      },
      "condition": null,
      "actions": [
        {
          "type": "stream_to_ui"
        }
      ]
    }
  ],
  "schema_mappings": [],
  "command_templates": [],
  "sinks": []
}
